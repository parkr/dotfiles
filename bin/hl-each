#!/usr/bin/env bash
#/ Usage: hl-each some series of bash commands
#/ Executes a shell script on each homelab machine.
#/ Homelab machines can be found in $HOME/code/puppet/code/hiera/hostname/*.yaml.
#/ Each filename is a hostname.
set -e
set -u
set -o pipefail

shift || true

# Print usage if no arguments
if [[ $# -eq 0 ]]; then
  echo "Usage: hl-each -- command [args...]" > /dev/stderr
  exit 1
fi

HIERA_PATH="$HOME/code/puppet/code/hiera/hostname"

# Check if directory exists
if [[ ! -d "$HIERA_PATH" ]]; then
  echo "Error: Directory $HIERA_PATH not found."
  exit 1
fi

# Prepare command escaping and a clean display name for safety and brevity
cmd_escaped=$(printf '%q ' "$@")
cmd_display=$(echo "$*" | tr -cd 'a-zA-Z0-9_./- ')
if [[ ${#cmd_display} -gt 35 ]]; then
  cmd_display="${cmd_display:0:32}..."
fi

# Loop through each hostname YAML file
for file in "$HIERA_PATH"/*.yaml; do
  # Handle cases where no files match the glob
  [[ -e "$file" ]] || continue

  # Extract the hostname from the filename
  hostname=$(basename "$file" .yaml)

  echo -e "\n\033[35m==> Running on $hostname...\033[0m"

  local_start=$(date +%s.%N 2>/dev/null || date +%s 2>/dev/null || echo 0)

  # Use ssh to run the command on each host and print command latency
  # We use BatchMode to avoid hangs and || true to continue even if one host fails
  ssh -o BatchMode=yes -o ConnectTimeout=5 "$hostname" -- "
    start=\$(date +%s.%N 2>/dev/null || date +%s 2>/dev/null || echo 0)
    $cmd_escaped
    exit_code=\$?
    end=\$(date +%s.%N 2>/dev/null || date +%s 2>/dev/null || echo 0)
    latency=\$(awk -v start=\"\$start\" -v end=\"\$end\" 'BEGIN { printf \"%.2f\", end - start }' 2>/dev/null || echo \"unknown\")
    printf '\\033[36m%s took %ss\\033[0m\\n' \"$cmd_display\" \"\$latency\"
    exit \$exit_code
  " || true

  local_end=$(date +%s.%N 2>/dev/null || date +%s 2>/dev/null || echo 0)
  total_duration=$(awk -v start="$local_start" -v end="$local_end" 'BEGIN { printf "%.2f", end - start }' 2>/dev/null || echo "unknown")
  echo -e "\033[32m$hostname completed in ${total_duration}s\033[0m"
done
